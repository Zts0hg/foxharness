          <mxGeometry x="500" y="300" width="600" height="360" as="geometry" />
        </mxCell>
        <mxCell id="p3_core" value="Agent 执行核心&lt;br&gt;&lt;span style=&quot;font-size:12px&quot;&gt;推理、行动、观察、停止条件&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D8F0DF;strokeColor=#267947;fontSize=18;fontStyle=1;fontColor=#233142;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="650" y="420" width="300" height="120" as="geometry" />
        </mxCell>

        <mxCell id="p3_ingress" value="入口接入可替换&lt;br&gt;TUI、CLI、聊天平台、评测任务&lt;br&gt;&lt;br&gt;边界：提交任务、接收进度、展示结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9F3FF;strokeColor=#6AA3D8;fontSize=14;fontStyle=1;fontColor=#233142;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="90" y="145" width="320" height="145" as="geometry" />
        </mxCell>
        <mxCell id="p3_model" value="模型通道可替换&lt;br&gt;OpenAI 兼容、Claude 兼容、未来协议&lt;br&gt;&lt;br&gt;边界：统一消息、工具意图、用量信息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4F4;strokeColor=#D46A6A;fontSize=14;fontStyle=1;fontColor=#233142;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="135" width="320" height="145" as="geometry" />
        </mxCell>
        <mxCell id="p3_output" value="输出通道可替换&lt;br&gt;终端界面、命令行输出、聊天回复&lt;br&gt;&lt;br&gt;边界：生命周期事件、最终消息、错误反馈" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9F3FF;strokeColor=#6AA3D8;fontSize=14;fontStyle=1;fontColor=#233142;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1190" y="145" width="320" height="145" as="geometry" />
        </mxCell>

        <mxCell id="p3_tools" value="工具能力可扩展&lt;br&gt;文件、命令、待办、技能、子任务、日志搜索&lt;br&gt;&lt;br&gt;边界：工具描述、调用参数、执行结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F9FC;strokeColor=#6D8791;fontSize=14;fontStyle=1;fontColor=#233142;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="90" y="465" width="320" height="155" as="geometry" />
        </mxCell>
        <mxCell id="p3_policy" value="策略机制可叠加&lt;br&gt;检查点、审批、安全拦截、错误恢复、提醒&lt;br&gt;&lt;br&gt;边界：执行前决策、运行中提示、恢复动作" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF1E3;strokeColor=#D8954D;fontSize=14;fontStyle=1;fontColor=#233142;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1190" y="465" width="320" height="155" as="geometry" />
        </mxCell>

        <mxCell id="p3_state" value="状态系统可演进&lt;br&gt;会话历史、计划、待办、记忆、压缩摘要、文件快照&lt;br&gt;&lt;br&gt;边界：状态读写、恢复、续接" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4EAFE;strokeColor=#9C75C9;fontSize=14;fontStyle=1;fontColor=#233142;arcSize=8;" vertex="1" parent="1">
