        </mxCell>

        <mxCell id="p3_tools" value="Extensible Tool Capabilities&lt;br&gt;Files, commands, todos, skills, subtasks, log search&lt;br&gt;&lt;br&gt;Boundary: tool descriptions, call parameters, execution results" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F9FC;strokeColor=#6D8791;fontSize=13;fontStyle=1;fontColor=#233142;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="90" y="465" width="320" height="155" as="geometry" />
        </mxCell>
        <mxCell id="p3_policy" value="Composable Policy Mechanisms&lt;br&gt;Checkpoints, approvals, safety gates, recovery, reminders&lt;br&gt;&lt;br&gt;Boundary: pre-run decisions, runtime prompts, recovery actions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF1E3;strokeColor=#D8954D;fontSize=13;fontStyle=1;fontColor=#233142;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1190" y="465" width="320" height="155" as="geometry" />
