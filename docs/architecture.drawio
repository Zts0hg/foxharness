          <mxGeometry x="500" y="300" width="600" height="360" as="geometry" />
        </mxCell>
        <mxCell id="p3_core" value="Agent Runtime Core&lt;br&gt;&lt;span style=&quot;font-size:12px&quot;&gt;Reasoning, actions, observations, stop conditions&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D8F0DF;strokeColor=#267947;fontSize=18;fontStyle=1;fontColor=#233142;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="650" y="420" width="300" height="120" as="geometry" />
        </mxCell>

        <mxCell id="p3_ingress" value="Replaceable Entry Adapters&lt;br&gt;TUI, CLI, chat platforms, evaluation runs&lt;br&gt;&lt;br&gt;Boundary: submit tasks, receive progress, present results" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9F3FF;strokeColor=#6AA3D8;fontSize=13;fontStyle=1;fontColor=#233142;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="90" y="145" width="320" height="145" as="geometry" />
        </mxCell>
        <mxCell id="p3_model" value="Replaceable Model Channels&lt;br&gt;OpenAI-compatible, Claude-compatible, future protocols&lt;br&gt;&lt;br&gt;Boundary: unified messages, tool intent, usage data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4F4;strokeColor=#D46A6A;fontSize=13;fontStyle=1;fontColor=#233142;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="135" width="320" height="145" as="geometry" />
        </mxCell>
        <mxCell id="p3_output" value="Replaceable Output Channels&lt;br&gt;Terminal UI, CLI output, chat replies&lt;br&gt;&lt;br&gt;Boundary: lifecycle events, final messages, error feedback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9F3FF;strokeColor=#6AA3D8;fontSize=13;fontStyle=1;fontColor=#233142;arcSize=8;" vertex="1" parent="1">
